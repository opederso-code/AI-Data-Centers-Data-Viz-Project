{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Serve PHP (localhost:8000)",
      "type": "shell",
      "command": "php",
      "args": [
        "-S",
        "localhost:8000",
        "-t",
        "${workspaceFolder}"
      ],
      "isBackground": true,
      "problemMatcher": {
        "owner": "php",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Development Server \\(http://localhost:8000\\) started",
          "endsPattern": "Development Server \\(http://localhost:8000\\) started"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      }
    }
  ]
}
